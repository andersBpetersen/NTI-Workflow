# Eksempel-workflow til automatisk Docker publish via GitHub Actions.
# IKKE AKTIV — omdøb til docker-publish.yml og tilpas før brug.
#
# Docker Hub (tickjf/nti-workflow):
#   REGISTRY_USERNAME = tickjf
#   REGISTRY_PASSWORD = Docker Hub access token
#   IMAGE_NAMESPACE   = tickjf
#   REGISTRY_HOST     = docker.io  (eller udelad registry i login-action)

name: Docker Publish (example)

on:
  workflow_dispatch:
    inputs:
      version:
        description: "Image version tag (fx 0.6.4)"
        required: true
        default: "0.6.4"
      push_latest:
        description: "Push også :latest tag"
        required: false
        default: "false"

env:
  IMAGE_NAME: nti-workflow

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.REGISTRY_USERNAME }}
          password: ${{ secrets.REGISTRY_PASSWORD }}

      - name: Build and push version tag
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: ${{ secrets.IMAGE_NAMESPACE }}/${{ env.IMAGE_NAME }}:${{ inputs.version }}

      - name: Build and push latest tag
        if: inputs.push_latest == 'true'
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: ${{ secrets.IMAGE_NAMESPACE }}/${{ env.IMAGE_NAME }}:latest
